# ICO Frontend Environment Variables
# Copy this file to .env and fill in the values

# Contract Addresses (required)
# These are the deployed contract addresses on Sepolia testnet
VITE_ICO_ADDRESS=0xYourICOContractAddress
VITE_TOKEN_ADDRESS=0xYourTokenContractAddress
VITE_VESTING_ADDRESS=0xYourVestingContractAddress

# API URL (required)
# Backend API endpoint for saving purchases and claims
# For local development: http://localhost:5000/api
# For production: https://api.yourdomain.com/api
VITE_API_URL=http://localhost:5000/api

# Instructions:
# 1. Deploy contracts using: npx hardhat run scripts/deploy.js --network sepolia
# 2. Copy the deployed contract addresses from the deployment output
# 3. Paste them above
# 4. Start the frontend: npm run dev
